AnimationName :: enum {
	None,
	Mouth_Talk,
	Bflap,
	Explosion,
	Squatman_Idle,
	Squatman_Dead,
	Squatman_Run_Down,
	Squatman_Run_Up,
	Squatman_Run_Right,
}

TagLoopDir :: enum {
	Forward,
	Reverse,
	Ping_Pong,
	Ping_Pong_Reverse,
}

// Any aseprite file with frames will create new animations. Also, any tags
// within the aseprite file will make that that into a separate animation.
AtlasAnimation :: struct {
	first_frame: TextureName,
	last_frame: TextureName,
	document_size: [2]f32,
	loop_direction: TagLoopDir,
	repeat: u16,
}

atlas_animations := [AnimationName]AtlasAnimation {
	.None = {},
	.Mouth_Talk = { first_frame = .Mouth_Talk0, last_frame = .Mouth_Talk2, loop_direction = .Forward, repeat = 0, document_size = {32, 32} },
	.Bflap = { first_frame = .Bflap0, last_frame = .Bflap1, loop_direction = .Forward, repeat = 0, document_size = {64, 64} },
	.Explosion = { first_frame = .Explosion0, last_frame = .Explosion3, loop_direction = .Forward, repeat = 0, document_size = {32, 32} },
	.Squatman_Idle = { first_frame = .Squatman0, last_frame = .Squatman0, loop_direction = .Forward, repeat = 0, document_size = {0, 0} },
	.Squatman_Dead = { first_frame = .Squatman1, last_frame = .Squatman1, loop_direction = .Forward, repeat = 0, document_size = {0, 0} },
	.Squatman_Run_Down = { first_frame = .Squatman2, last_frame = .Squatman3, loop_direction = .Forward, repeat = 0, document_size = {0, 0} },
	.Squatman_Run_Up = { first_frame = .Squatman4, last_frame = .Squatman5, loop_direction = .Forward, repeat = 0, document_size = {0, 0} },
	.Squatman_Run_Right = { first_frame = .Squatman6, last_frame = .Squatman9, loop_direction = .Forward, repeat = 0, document_size = {0, 0} },
}

